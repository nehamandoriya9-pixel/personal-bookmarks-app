# Supabase (Dashboard → Settings → API → Project URL)
# Use the root URL only — do NOT append /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Resend (https://resend.com/api-keys) — server-only, never expose to the client
RESEND_API_KEY=re_your_resend_api_key
# Dev/testing sender (Resend): Bookmarks App <onboarding@resend.dev>
RESEND_FROM_EMAIL=Bookmarks App <onboarding@resend.dev>

# App URL for auth redirects and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
